# ── Email (SMTP) configuration ────────────────────────────────────────────────
# Copy this file to `.env` (same folder) and fill in real values.
# The .env file is git-ignored and never committed.
#
# Microsoft 365 / Outlook:
#   - Host/port below are the M365 defaults.
#   - SMTP_USER is your full email address.
#   - SMTP_PASSWORD must be an APP PASSWORD (not your normal password) if your
#     account has MFA enabled. Create one at https://account.microsoft.com/security
#   - Your tenant must allow SMTP AUTH for the mailbox.

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=you@axelautomotive.com
SMTP_PASSWORD=your-app-password-here
# Optional — defaults to SMTP_USER if left blank:
SMTP_FROM=
# Optional display name on the From header:
SMTP_FROM_NAME=AXEL Validator

# ── Database ──────────────────────────────────────────────────────────────────
# App data (clients, conditions, schedules, runs, AXEL queries/connections) is
# stored via SQLAlchemy. Unset → local SQLite file backend/data/axel_validator.db
# ($0, zero-config). Set DATABASE_URL to use a production database, e.g.:
#   DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/axel
#   DATABASE_URL=mssql+pymssql://user:pass@host:1433/axel
DATABASE_URL=

# ── AXEL data source (per-client SQL queries) ─────────────────────────────────
# Per-client DB credentials are entered in the app UI and stored ENCRYPTED in
# backend/data/axel_connections.json (git-ignored). The encryption key is read
# from AXEL_SECRET_KEY when set; otherwise a key is generated and cached in
# backend/data/.secret_key (fine for local dev, NOT for multi-instance prod).
#
# In production (Azure App Service) set a fixed key so secrets stay decryptable
# across restarts/instances. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AXEL_SECRET_KEY=
